{
  "name": "@git-stacks/protocol",
  "version": "0.22.0-rc.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnexai/git-stacks.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs protocol",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "gitStacksBuild": {
    "platform": "neutral",
    "target": "es2024"
  }
}
