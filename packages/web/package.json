{
  "name": "@git-stacks/web",
  "version": "0.22.0-rc.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnexai/git-stacks.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./manifest.json": "./dist/manifest.json"
  },
  "scripts": {
    "build": "node ../../scripts/build-web.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@git-stacks/client": "0.22.0-rc.5",
    "@git-stacks/protocol": "0.22.0-rc.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "solid-js": "1.9.12"
  },
  "gitStacksBuild": {
    "entries": [
      "src/app.ts"
    ],
    "platform": "browser",
    "target": "es2024"
  }
}
