{
  "name": "@git-stacks/service",
  "version": "0.21.0-rc.1",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "files": ["dist", "src"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs service",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@git-stacks/client": "0.21.0-rc.1",
    "@git-stacks/core": "0.21.0-rc.1",
    "@git-stacks/protocol": "0.21.0-rc.1",
    "@git-stacks/web": "0.21.0-rc.1",
    "node-pty": "1.2.0-beta.14",
    "ws": "8.21.1"
  },
  "gitStacksBuild": {
    "platform": "node",
    "entries": ["src/index.ts", "src/client.ts"]
  },
  "devDependencies": {
    "@types/ws": "8.18.1"
  }
}
