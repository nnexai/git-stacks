{
  "name": "@git-stacks/service",
  "version": "0.21.0-rc.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "bun": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./remote": {
      "types": "./src/remote.ts",
      "import": "./dist/remote.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs service",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fails-components/webtransport": "1.6.6",
    "@fails-components/webtransport-transport-http3-quiche": "1.6.6",
    "@git-stacks/client": "0.21.0-rc.1",
    "@git-stacks/core": "0.21.0-rc.1",
    "@git-stacks/protocol": "0.21.0-rc.1",
    "@napi-rs/keyring": "1.3.0",
    "@peculiar/x509": "2.0.0",
    "node-pty": "1.2.0-beta.14",
    "reflect-metadata": "0.2.2"
  },
  "gitStacksBuild": {
    "platform": "node",
    "entries": [
      "src/index.ts",
      "src/client.ts",
      "src/remote.ts"
    ]
  }
}
