{
  "name": "@git-stacks/tui",
  "version": "0.21.0-rc.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnexai/git-stacks.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "bunfig.toml"
  ],
  "packageManager": "bun@1.3.14",
  "type": "module",
  "bin": {
    "git-stacks-tui": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@git-stacks/client": "0.21.0-rc.5",
    "@git-stacks/core": "0.21.0-rc.5",
    "@git-stacks/protocol": "0.21.0-rc.5",
    "@git-stacks/service": "0.21.0-rc.5",
    "@opentui/core": "0.4.3",
    "@opentui/solid": "0.4.3",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "gitStacksBuild": {
    "runtime": "bun",
    "platform": "neutral",
    "target": "es2024"
  }
}
