{
  "name": "git-stacks",
  "version": "0.11.1",
  "description": "Git worktree workspace manager — templates, workspaces, and multi-repo orchestration",
  "license": "MIT",
  "author": "nnexai",
  "keywords": [
    "git",
    "worktree",
    "workspace",
    "multi-repo",
    "template",
    "cli",
    "bun",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "git-stacks": "./src/index.ts"
  },
  "files": [
    "src",
    "bunfig.toml",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun run scripts/test-runner.ts",
    "test:unit": "bun run scripts/test-runner.ts --unit",
    "test:integ": "bun run scripts/test-runner.ts --integ",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@opentui/core": "^0.1.92",
    "@opentui/solid": "^0.1.92",
    "commander": "^14.0.3",
    "opentui-spinner": "^0.0.6",
    "solid-js": "^1.9.12",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  }
}
