{
  "name": "git-stacks",
  "version": "0.21.0-rc.4",
  "workspaces": [
    "packages/protocol",
    "packages/client",
    "packages/core",
    "packages/cli",
    "packages/service",
    "packages/web",
    "packages/tui"
  ],
  "packageManager": "npm@11.17.0",
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "node-pty@1.2.0-beta.14": true,
    "@fails-components/webtransport-transport-http3-quiche@1.6.6": true
  },
  "engines": {
    "node": ">=24"
  },
  "description": "Git worktree workspace manager — templates, workspaces, and multi-repo orchestration",
  "license": "MIT",
  "author": "nnexai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnexai/git-stacks.git"
  },
  "keywords": [
    "git",
    "worktree",
    "workspace",
    "multi-repo",
    "template",
    "cli",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "git-stacks": "bin/git-stacks.js"
  },
  "files": [
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:packages",
    "build:packages": "node scripts/build-package.mjs --all",
    "clean": "node scripts/clean-packages.mjs",
    "dev": "npm run build:packages && node packages/cli/dist/index.js web",
    "dev:web": "npm run build:packages && node packages/cli/dist/index.js web",
    "test": "npm run build:packages && npm run test:vitest && npm run test:node && npm run test:tui",
    "test:vitest": "GIT_STACKS_KEY_STORE=file vitest run",
    "test:unit": "GIT_STACKS_KEY_STORE=file vitest run tests/lib tests/service tests/tui/workspace-clone.test.ts tests/tui/workspace-wizard.test.ts",
    "pretest:unit": "npm run build:packages",
    "test:integ": "GIT_STACKS_KEY_STORE=file vitest run tests/commands",
    "pretest:integ": "npm run build:packages",
    "test:tui": "node scripts/test-tui.mjs",
    "test:deps": "node scripts/check-architecture.mjs --cycles",
    "test:architecture": "node scripts/check-architecture.mjs",
    "test:node": "GIT_STACKS_KEY_STORE=file node --test tests/architecture/*.test.mjs tests/conformance/*.test.mjs tests/core/*.test.mjs tests/cli/*.test.mjs tests/service-node/*.test.mjs",
    "check:packages": "npm run build:packages && npm run tui:build && node scripts/check-packages.mjs",
    "audit:licenses": "node scripts/check-licenses.mjs",
    "audit:runtime": "npm audit --omit=dev --workspace @git-stacks/cli --workspace @git-stacks/service",
    "coverage": "GIT_STACKS_KEY_STORE=file vitest run --coverage",
    "verify": "tsx scripts/verify.ts",
    "verify:prereqs": "tsx scripts/verify-prereqs.ts",
    "verify:gates": "tsx scripts/verify-gates.ts",
    "web:build": "node scripts/build-web.mjs",
    "tui:build": "npm run build -w @git-stacks/tui",
    "web:typecheck": "npm run typecheck -w @git-stacks/web",
    "verify:functional": "tsx scripts/functional-coverage-readiness.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:legacy": "tsc --noEmit",
    "release:check": "node scripts/release-rc-check.mjs",
    "pack:release": "npm run check:packages && node scripts/pack-release.mjs",
    "prepublishOnly": "npm run build:packages && npm run typecheck && npm run test:node"
  },
  "dependencies": {
    "@git-stacks/cli": "0.21.0-rc.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "^0.25.0",
    "tsx": "4.23.1",
    "typescript": "^6.0.2",
    "vitest": "4.1.10"
  }
}
