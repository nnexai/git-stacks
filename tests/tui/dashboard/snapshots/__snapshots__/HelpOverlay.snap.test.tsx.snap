// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`HelpOverlay snapshots renders full keybinding reference for workspaces tab 1`] = `
"    │ Global:                                                              │    
    │ 1 / 2 / 3 Switch tabs (Workspaces / Templates / Repos)               │    
    │ [ / ] Previous / next tab                                            │    
    │ r Refresh current tab                                                │    
    │ ? Toggle this help                                                   │    
    │ q Quit (from list view only)                                         │    
    │                                                                      │    
    │ Navigation:                                                          │    
    │ ↑ ↓ / j k Move cursor                                                │    
    │ / Start filter                                                       │    
    │ Esc Back / clear filter / close overlay                              │    
    │                                                                      │    
    │ Workspaces tab:                                                      │    
    │ Enter Open action menu                                               │    
    │ Space Select for batch operation                                     │    
    │ m View workspace messages                                            │    
    │ Actions: o=Open e=Edit n=Rename u=Run m=Merge c=Clean r=Remove       │    
    │                                                                      │    
    │ Templates tab:                                                       │    
    │ Enter Open action menu                                               │    
    │ e=Edit($EDITOR) c=Clone r=Remove                                     │    
    │                                                                      │    
    │ Repos tab:                                                           │    
    │ (read-only — no actions)                                             │    
"
`;
