{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "git-stacks message clear --workspace git-stacks --from claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "git-stacks message send \"Claude is asking a question — input needed\" --workspace git-stacks --from claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git-stacks message send \"Claude has finished and may need your attention\" --workspace git-stacks --from claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git-stacks message clear --workspace git-stacks --from claude"
          }
        ]
      }
    ]
  }
}
