+    export fn ghostty_surface_process_absent(surface: *Surface, identity: ProcessIdentity) bool {
+        return switch (surface.core_surface.io.backend) {
+            .exec => |*exec| exec.processAbsent(identity),
+            .manual => true,
+        };
+    }
