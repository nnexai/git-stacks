+/// Return a reuse-resistant identity for the direct child. Linux start time
+/// from /proc is scoped with PID and process group so embedders never control
+/// a process by PID alone.
+pub fn processIdentity(self: *Exec) ?ProcessIdentity {
+    if (comptime builtin.os.tag != .linux) return null;
+    const command = switch (self.subprocess.process orelse return null) {
+        .fork_exec => |*value| value,
+        .flatpak => return null,
+    };
+    const pid = command.pid orelse return null;
+    const pgid = Subprocess.c.getpgid(pid);
+    if (pid <= 1 or pgid <= 1 or pgid == Subprocess.c.getpgid(0)) return null;
+    const birth = linuxBirthToken(pid) orelse return null;
+    return .{ .pid = @intCast(pid), .pgid = @intCast(pgid), .linux_birth_token = birth };
+}
+
+pub fn signalProcessGroup(self: *Exec, identity: ProcessIdentity, signal: i32) bool {
+    const current = self.processIdentity() orelse return false;
+    if (!std.meta.eql(current, identity)) return false;
+    if (signal != Subprocess.c.SIGHUP and signal != Subprocess.c.SIGTERM and signal != Subprocess.c.SIGKILL) return false;
+    return posix.errno(Subprocess.c.killpg(@intCast(identity.pgid), signal)) == .SUCCESS;
+}
+
+pub fn processAbsent(self: *Exec, identity: ProcessIdentity) bool {
+    const current = self.processIdentity() orelse return true;
+    if (!std.meta.eql(current, identity)) return false;
+    return posix.errno(Subprocess.c.kill(@intCast(identity.pid), 0)) == .SRCH;
+}
+
+fn linuxBirthToken(pid: std.posix.pid_t) ?u64 {
+    var path_buf: [64]u8 = undefined;
+    const path = std.fmt.bufPrint(&path_buf, "/proc/{d}/stat", .{pid}) catch return null;
+    const file = std.fs.openFileAbsolute(path, .{}) catch return null;
+    defer file.close();
+    var buf: [4096]u8 = undefined;
+    const stat = file.readAll(&buf) catch return null;
+    const close_paren = std.mem.lastIndexOfScalar(u8, buf[0..stat], ')') orelse return null;
+    var fields = std.mem.tokenizeScalar(u8, buf[close_paren + 1 .. stat], ' ');
+    var index: usize = 3;
+    while (fields.next()) |field| : (index += 1) {
+        if (index == 22) return std.fmt.parseUnsigned(u64, field, 10) catch null;
+    }
+    return null;
+}
