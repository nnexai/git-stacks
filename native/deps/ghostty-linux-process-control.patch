+    export fn ghostty_surface_process_signal_group(surface: *Surface, identity: ProcessIdentity, signal: i32) bool {
+        return switch (surface.core_surface.io.backend) {
+            .exec => |*exec| exec.signalProcessGroup(identity, signal),
+            .manual => false,
+        };
+    }
+
+    export fn ghostty_surface_process_reap(surface: *Surface, identity: ProcessIdentity) bool {
+        if (!surface.core_surface.child_exited) return false;
+        return switch (surface.core_surface.io.backend) {
+            .exec => |*exec| exec.processAbsent(identity),
+            .manual => false,
+        };
+    }
